modules = ["nodejs-24", "python-3.11", "javascript", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 19515
externalPort = 3000

[[ports]]
localPort = 25261
externalPort = 3001

[[ports]]
localPort = 25262
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["zip"]

[userenv]

[userenv.shared]
RESEND_API_KEY = "re_6tYLWYmr_D7vxwb2oSt2VU5f7ovfwzFfK"
RESEND_FROM_EMAIL = "onboarding@resend.dev"
